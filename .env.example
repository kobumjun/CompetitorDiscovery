# ============================================
# Competitor Discovery from Threads
# Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.

# --- Supabase ---
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- OpenAI ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# --- X (Twitter) API ---
# Get from: https://developer.x.com/en/portal/dashboard
# Requires at least Basic tier ($100/mo) for tweet lookup + search
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# --- Lemon Squeezy ---
# Get from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret

# Plan Variant IDs (create these in Lemon Squeezy dashboard)
LEMONSQUEEZY_LITE_VARIANT_ID=your-lite-variant-id
LEMONSQUEEZY_STANDARD_VARIANT_ID=your-standard-variant-id
LEMONSQUEEZY_PRO_VARIANT_ID=your-pro-variant-id

# --- App ---
# Used for Lemon post-checkout redirect (product_options.redirect_url)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional: Analytics ---
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

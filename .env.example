# ============================================
# ProposalPilot
# Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.

# --- Supabase ---
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- OpenAI ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# --- Serper ---
# Get from: https://serper.dev/api-key
SERPER_API_KEY=

# --- Lemon Squeezy ---
# Get from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret

# Subscription variant IDs (create these in Lemon Squeezy dashboard)
LEMONSQUEEZY_PRO_VARIANT_ID=your-pro-variant-id
LEMONSQUEEZY_AGENCY_VARIANT_ID=your-agency-variant-id

# One-time credit pack variant IDs (separate products/variants from subscriptions)
# TODO: Add Lemon Squeezy variant ID per pack after creating one-time products in Lemon.
LEMONSQUEEZY_ONETIME_STARTER_VARIANT_ID=
LEMONSQUEEZY_ONETIME_GROWTH_VARIANT_ID=
LEMONSQUEEZY_ONETIME_BULK_VARIANT_ID=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
